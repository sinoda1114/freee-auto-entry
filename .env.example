# freee Developers で発行したOAuthアプリの認証情報
# https://app.secure.freee.co.jp/developers のアプリ管理 > 新規追加 で取得する
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=

# freee側アプリ設定のコールバックURLと一致させること
FREEE_REDIRECT_URI=http://localhost:3000/api/auth/callback/freee

# サーバーサイドでセッション/トークンを暗号化するためのランダム文字列
# 生成例: openssl rand -base64 32
AUTH_SECRET=

# 絶対URLが必要な箇所で使用（ハードコード禁止）
# Android Suica アプリの BuildConfig.SITE_URL も同じ値に合わせる
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 経費登録を許可する事業所 ID（省略時: 11122591 = 株式会社Waalsforce）
FREEE_EXPENSE_COMPANY_ID=11122591

# 定型請求テンプレートと作成履歴を保存するTurso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ルール作成フォームの AI 提案（Gemini 3.1 Flash Lite）。ボタン押下時のみ使用
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 省略時: gemini-3.1-flash-lite
# GEMINI_MODEL=gemini-3.1-flash-lite
